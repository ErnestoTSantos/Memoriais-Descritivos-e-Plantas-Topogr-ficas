DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=.railway.app,localhost,127.0.0.1

# Railway usually provides PORT automatically.
PORT=8000

# Prefer DATABASE_URL in Railway when using the PostgreSQL plugin.
# The database must have PostGIS enabled for django.contrib.gis.db.backends.postgis.
DATABASE_URL=postgresql://user:password@host:5432/geomemorial

# Alternative database variables, useful for Docker Compose or providers that expose PG*.
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=geomemorial
POSTGRES_USER=geomemorial
POSTGRES_PASSWORD=geomemorial
PGHOST=
PGPORT=
PGDATABASE=
PGUSER=
PGPASSWORD=

# Set to 0 if you do not use S3-compatible storage in the deployment.
USE_S3=0
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=geomemorial
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=us-east-1
